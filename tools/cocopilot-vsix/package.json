    "configuration": {
      "title": "Cocopilot",
      "properties": {
        "cocopilot.apiBase": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL for the Cocopilot API and dashboard."
        },
        "cocopilot.projectId": {
          "type": "string",
          "default": "",
          "description": "Project ID for Cocopilot."
        },
        "cocopilot.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional API key for authenticating with the Cocopilot server."
        },
        "cocopilot.autoStartMcpServer": {
          "type": "boolean",
          "default": false,
          "description": "Start the MCP server automatically when the VSIX activates."
        }
      }
